<EditCalorieTargetSheet>:
    background: " "
    background_color: 0, 0, 0, 0
    auto_dismiss: False

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: app.theme_cls.backgroundColor

        MDBoxLayout:
            size_hint_y: None
            height: "56dp"
            md_bg_color: app.theme_cls.primaryColor
            spacing: "4dp"
            padding: ["4dp", "0dp", "16dp", "0dp"]

            MDIconButton:
                icon: "arrow-left"
                theme_icon_color: "Custom"
                icon_color: 1, 1, 1, 1
                pos_hint: {"center_y": 0.5}
                on_release: root.dismiss()

            MDLabel:
                text: "Caloric requirement"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                font_style: "Title"
                role: "medium"
                halign: "left"
                valign: "center"

        MDScrollView:
            size_hint_y: 1
            bar_width: dp(6)
            scroll_type: ["bars", "content"]
            scroll_distance: dp(28)
            do_scroll_x: False

            MDBoxLayout:
                orientation: "vertical"
                padding: ["16dp", "16dp", "16dp", "16dp"]
                spacing: "16dp"
                size_hint_y: None
                height: self.minimum_height

                MDLabel:
                    text: root.hero_kcal_text
                    font_style: "Title"
                    role: "large"
                    halign: "center"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    size_hint_y: None
                    height: "56dp"

                MDLabel:
                    text: "kcal"
                    font_style: "Title"
                    role: "small"
                    halign: "center"
                    theme_text_color: "Custom"
                    text_color: app.theme_cls.primaryColor
                    size_hint_y: None
                    height: "28dp"

                MDLabel:
                    text: root.maintenance_line
                    font_style: "Body"
                    role: "small"
                    halign: "center"
                    theme_text_color: "Secondary"
                    size_hint_y: None
                    height: "28dp"
                    text_size: self.width, None
                    opacity: 1 if root.maintenance_line else 0

                MDBoxLayout:
                    size_hint_y: None
                    height: "48dp"
                    padding: ["0dp", "8dp", "0dp", "0dp"]
                    MDLabel:
                        text: "Use recommended"
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1
                        font_style: "Body"
                        role: "medium"
                        valign: "center"
                    Widget:
                        size_hint_x: 1
                    MDSwitch:
                        id: use_rec_switch
                        disabled: not root.body_available
                        on_active: root.on_use_switch_active(self, self.active)

                MDBoxLayout:
                    size_hint_y: None
                    height: "48dp"
                    spacing: "8dp"

                    MDLabel:
                        text: "Caloric requirement"
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1
                        font_style: "Body"
                        role: "medium"
                        halign: "left"
                        valign: "middle"
                        size_hint_x: 0.5
                        text_size: self.width, None

                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_x: 0.5

                        Widget:
                            size_hint_x: 1

                        MDBoxLayout:
                            orientation: "horizontal"
                            size_hint_x: None
                            spacing: "6dp"

                            TextInput:
                                id: kcal_edit
                                multiline: False
                                write_tab: False
                                readonly: root.use_recommended
                                disabled: not root.body_available
                                input_type: "number"
                                background_normal: ""
                                background_active: ""
                                background_color: 0, 0, 0, 0
                                border: [0, 0, 0, 0]
                                cursor_color: 1, 1, 1, 1
                                foreground_color: 1, 1, 1, 1
                                hint_text: ""
                                size_hint_x: None
                                width: dp(128)
                                height: dp(40)
                                font_size: dp(16)
                                padding: ["6dp", "8dp", "6dp", "8dp"]
                                halign: "right"
                                input_filter: "float"
                                on_text: root.on_kcal_field_text(self.text)

                            MDLabel:
                                text: "kcal"
                                theme_text_color: "Secondary"
                                font_style: "Body"
                                role: "medium"
                                valign: "middle"
                                halign: "left"
                                size_hint_x: None
                                width: dp(38)

                FloatLayout:
                    size_hint_y: None
                    height: "52dp"

                    CalorieSliderTrack:
                        pos_hint: {"center_x": 0.5, "center_y": 0.5}
                        size_hint: 0.92, None
                        height: "8dp"

                    Slider:
                        id: slider_adj
                        min: -50
                        max: 50
                        step: 1
                        disabled: not root.body_available
                        pos_hint: {"x": 0, "y": 0}
                        size_hint: 1, 1
                        padding: "12dp"
                        cursor_size: [dp(28), dp(28)]
                        on_value: root.on_slider_changed(self.value)

                MDLabel:
                    text: root.modification_line
                    font_style: "Body"
                    role: "small"
                    halign: "center"
                    valign: "top"
                    theme_text_color: "Secondary"
                    size_hint_x: 1
                    size_hint_y: None
                    height: "40dp"
                    text_size: self.width, None
                    opacity: 1 if root.modification_line else 0

                MDCard:
                    orientation: "vertical"
                    padding: "14dp"
                    radius: [dp(12)]
                    elevation: 0
                    md_bg_color: [0.14, 0.22, 0.38, 1]
                    size_hint_y: None
                    height: self.minimum_height

                    MDLabel:
                        text: "Those are the calories you need to eat each day to accomplish your goal, depending on your level of physical activity, sex, age, etc. Your goal can increase or decrease this value up to 20%; beyond that limit is not recommended nor healthy."
                        font_style: "Body"
                        role: "small"
                        theme_text_color: "Custom"
                        text_color: 0.92, 0.94, 0.98, 1
                        font_size: "12sp"
                        text_size: self.width, None
                        halign: "left"

                MDLabel:
                    text: root.info_notice
                    font_style: "Body"
                    role: "small"
                    theme_text_color: "Error"
                    halign: "center"
                    text_size: self.width, None
                    size_hint_y: None
                    height: "48dp"
                    opacity: 1 if root.info_notice else 0

                MDButton:
                    style: "filled"
                    size_hint_y: None
                    height: "48dp"
                    size_hint_x: 1
                    disabled: not root.body_available
                    on_release: root.save_calories()

                    MDButtonText:
                        text: "Save"

<EditMacrosSheet>:
    background: " "
    background_color: 0, 0, 0, 0
    auto_dismiss: False

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: app.theme_cls.backgroundColor

        MDBoxLayout:
            size_hint_y: None
            height: "56dp"
            md_bg_color: app.theme_cls.primaryColor
            spacing: "4dp"
            padding: ["4dp", "0dp", "16dp", "0dp"]

            MDIconButton:
                icon: "arrow-left"
                theme_icon_color: "Custom"
                icon_color: 1, 1, 1, 1
                pos_hint: {"center_y": 0.5}
                on_release: root.request_back()

            MDLabel:
                text: "Macronutrients"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                font_style: "Title"
                role: "medium"
                halign: "left"
                valign: "center"

        MDScrollView:
            MDBoxLayout:
                orientation: "vertical"
                padding: ["16dp", "12dp", "16dp", "24dp"]
                spacing: "16dp"
                size_hint_y: None
                height: self.minimum_height

                MDLabel:
                    text: "Macronutrients distribution"
                    font_style: "Title"
                    role: "large"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    size_hint_y: None
                    text_size: self.width, None
                    halign: "left"

                MDCard:
                    orientation: "vertical"
                    padding: ["12dp", "10dp", "6dp", "12dp"]
                    spacing: "0dp"
                    radius: [dp(12)]
                    elevation: 0
                    md_bg_color: app.theme_cls.surfaceContainerColor
                    size_hint_y: None
                    height: self.minimum_height

                    MDBoxLayout:
                        size_hint_y: None
                        height: "42dp"
                        padding: ["0dp", "5dp", "0dp", "5dp"]
                        MDLabel:
                            text: "Set in"
                            size_hint_x: None
                            width: dp(108)
                            valign: "middle"
                            halign: "left"
                            theme_text_color: "Secondary"
                            font_style: "Body"
                            role: "medium"
                        AnchorLayout:
                            anchor_x: "right"
                            anchor_y: "center"
                            size_hint_x: 1
                            MDButton:
                                style: "text"
                                size_hint_x: None
                                padding: [0, 0, 0, 0]
                                pos_hint: {"center_y": 0.5}
                                on_release: root.open_mode_menu()
                                MDButtonText:
                                    text: root.mode_display_text
                                    theme_text_color: "Custom"
                                    text_color: app.theme_cls.primaryColor
                                    padding: [0, 0, 0, 0]

                    MDBoxLayout:
                        size_hint_y: None
                        size_hint_x: 1
                        height: "1dp"
                        md_bg_color: app.theme_cls.onSurfaceColor
                        opacity: 0.22

                    MDBoxLayout:
                        size_hint_y: None
                        height: "42dp"
                        padding: ["0dp", "5dp", "0dp", "5dp"]
                        MDLabel:
                            text: "Carbohydrate"
                            size_hint_x: None
                            width: dp(108)
                            valign: "middle"
                            halign: "left"
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            font_style: "Body"
                            role: "medium"
                        AnchorLayout:
                            anchor_x: "right"
                            anchor_y: "center"
                            size_hint_x: 1
                            MDCard:
                                orientation: "horizontal"
                                size_hint_x: None
                                size_hint_y: None
                                width: dp(112)
                                height: dp(36)
                                padding: ["6dp", "0dp", "4dp", "0dp"]
                                spacing: "0dp"
                                radius: [dp(8)]
                                elevation: 0
                                md_bg_color: 0.15, 0.19, 0.24, 1
                                TextInput:
                                    id: carbs_input
                                    multiline: False
                                    write_tab: False
                                    background_normal: ""
                                    background_active: ""
                                    background_color: 0, 0, 0, 0
                                    border: [0, 0, 0, 0]
                                    cursor_color: 1, 1, 1, 1
                                    foreground_color: 1, 1, 1, 1
                                    size_hint_x: None
                                    width: dp(64)
                                    height: dp(34)
                                    font_size: dp(16)
                                    padding: ["0dp", "6dp", "0dp", "6dp"]
                                    halign: "right"
                                    input_filter: "float"
                                    on_text: root.sync_from_field("carbs", self.text)
                                MDLabel:
                                    text: root.unit_suffix
                                    size_hint_x: None
                                    width: dp(22)
                                    halign: "left"
                                    valign: "middle"
                                    theme_text_color: "Secondary"
                                    font_style: "Body"
                                    role: "medium"

                    MDBoxLayout:
                        size_hint_y: None
                        size_hint_x: 1
                        height: "1dp"
                        md_bg_color: app.theme_cls.onSurfaceColor
                        opacity: 0.22

                    MDBoxLayout:
                        size_hint_y: None
                        height: "42dp"
                        padding: ["0dp", "5dp", "0dp", "5dp"]
                        MDLabel:
                            text: "Protein"
                            size_hint_x: None
                            width: dp(108)
                            valign: "middle"
                            halign: "left"
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            font_style: "Body"
                            role: "medium"
                        AnchorLayout:
                            anchor_x: "right"
                            anchor_y: "center"
                            size_hint_x: 1
                            MDCard:
                                orientation: "horizontal"
                                size_hint_x: None
                                size_hint_y: None
                                width: dp(112)
                                height: dp(36)
                                padding: ["6dp", "0dp", "4dp", "0dp"]
                                spacing: "0dp"
                                radius: [dp(8)]
                                elevation: 0
                                md_bg_color: 0.15, 0.19, 0.24, 1
                                TextInput:
                                    id: protein_input
                                    multiline: False
                                    write_tab: False
                                    background_normal: ""
                                    background_active: ""
                                    background_color: 0, 0, 0, 0
                                    border: [0, 0, 0, 0]
                                    cursor_color: 1, 1, 1, 1
                                    foreground_color: 1, 1, 1, 1
                                    size_hint_x: None
                                    width: dp(64)
                                    height: dp(34)
                                    font_size: dp(16)
                                    padding: ["0dp", "6dp", "0dp", "6dp"]
                                    halign: "right"
                                    input_filter: "float"
                                    on_text: root.sync_from_field("protein", self.text)
                                MDLabel:
                                    text: root.unit_suffix
                                    size_hint_x: None
                                    width: dp(22)
                                    halign: "left"
                                    valign: "middle"
                                    theme_text_color: "Secondary"
                                    font_style: "Body"
                                    role: "medium"

                    MDBoxLayout:
                        size_hint_y: None
                        size_hint_x: 1
                        height: "1dp"
                        md_bg_color: app.theme_cls.onSurfaceColor
                        opacity: 0.22

                    MDBoxLayout:
                        size_hint_y: None
                        height: "42dp"
                        padding: ["0dp", "5dp", "0dp", "5dp"]
                        MDLabel:
                            text: "Fat"
                            size_hint_x: None
                            width: dp(108)
                            valign: "middle"
                            halign: "left"
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            font_style: "Body"
                            role: "medium"
                        AnchorLayout:
                            anchor_x: "right"
                            anchor_y: "center"
                            size_hint_x: 1
                            MDCard:
                                orientation: "horizontal"
                                size_hint_x: None
                                size_hint_y: None
                                width: dp(112)
                                height: dp(36)
                                padding: ["6dp", "0dp", "4dp", "0dp"]
                                spacing: "0dp"
                                radius: [dp(8)]
                                elevation: 0
                                md_bg_color: 0.15, 0.19, 0.24, 1
                                TextInput:
                                    id: fat_input
                                    multiline: False
                                    write_tab: False
                                    background_normal: ""
                                    background_active: ""
                                    background_color: 0, 0, 0, 0
                                    border: [0, 0, 0, 0]
                                    cursor_color: 1, 1, 1, 1
                                    foreground_color: 1, 1, 1, 1
                                    size_hint_x: None
                                    width: dp(64)
                                    height: dp(34)
                                    font_size: dp(16)
                                    padding: ["0dp", "6dp", "0dp", "6dp"]
                                    halign: "right"
                                    input_filter: "float"
                                    on_text: root.sync_from_field("fat", self.text)
                                MDLabel:
                                    text: root.unit_suffix
                                    size_hint_x: None
                                    width: dp(22)
                                    halign: "left"
                                    valign: "middle"
                                    theme_text_color: "Secondary"
                                    font_style: "Body"
                                    role: "medium"

                MDBoxLayout:
                    size_hint_y: None
                    height: "100dp"
                    spacing: "8dp"

                    MDCard:
                        padding: "10dp"
                        radius: [dp(12)]
                        elevation: 0
                        md_bg_color: app.theme_cls.surfaceContainerColor

                        MDLabel:
                            markup: True
                            text: root.sheet_carbs_breakdown_text
                            halign: "center"
                            valign: "middle"
                            text_size: self.size
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            font_style: "Body"
                            role: "small"

                    MDCard:
                        padding: "10dp"
                        radius: [dp(12)]
                        elevation: 0
                        md_bg_color: app.theme_cls.surfaceContainerColor

                        MDLabel:
                            markup: True
                            text: root.sheet_protein_breakdown_text
                            halign: "center"
                            valign: "middle"
                            text_size: self.size
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            font_style: "Body"
                            role: "small"

                    MDCard:
                        padding: "10dp"
                        radius: [dp(12)]
                        elevation: 0
                        md_bg_color: app.theme_cls.surfaceContainerColor

                        MDLabel:
                            markup: True
                            text: root.sheet_fat_breakdown_text
                            halign: "center"
                            valign: "middle"
                            text_size: self.size
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            font_style: "Body"
                            role: "small"

                MDCard:
                    size_hint_y: None
                    height: "72dp" if root.validation_message else "0dp"
                    opacity: 1 if root.validation_message else 0
                    padding: "12dp"
                    radius: [dp(10)]
                    elevation: 0
                    md_bg_color: [0.18, 0.38, 0.72, 1]

                    MDLabel:
                        text: root.validation_message
                        halign: "center"
                        valign: "middle"
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1
                        font_style: "Body"
                        role: "small"
                        text_size: self.width, None

                MacroPieChart:
                    id: pie_chart
                    protein_pct: root.draft_protein_pct
                    carbs_pct: root.draft_carbs_pct
                    fat_pct: root.draft_fat_pct

                AnchorLayout:
                    size_hint_y: None
                    height: "52dp"
                    anchor_x: "center"
                    anchor_y: "center"

                    MDButton:
                        style: "filled"
                        size_hint_x: None
                        width: dp(200)
                        disabled: not root.can_save
                        on_release: root.save_changes()

                        MDButtonText:
                            text: "Save"

<GoalsScreen>:
    MDBoxLayout:
        orientation: "vertical"

        MDBoxLayout:
            size_hint_y: None
            height: "56dp"
            md_bg_color: app.theme_cls.primaryColor
            padding: ["16dp", "0dp", "16dp", "0dp"]

            MDLabel:
                text: "Goals"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                font_style: "Title"
                role: "medium"
                halign: "center"
                valign: "center"

        MDScrollView:
            MDBoxLayout:
                orientation: "vertical"
                padding: ["16dp", "16dp", "16dp", "24dp"]
                spacing: "16dp"
                size_hint_y: None
                height: self.minimum_height

                MDCard:
                    padding: "16dp"
                    radius: [dp(12)]
                    elevation: 1
                    size_hint_y: None
                    height: "88dp"
                    ripple_behavior: True
                    on_release: root.open_calorie_editor()

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: "4dp"

                        MDLabel:
                            text: "Daily calorie target"
                            font_style: "Label"
                            role: "medium"
                            theme_text_color: "Secondary"

                        MDLabel:
                            id: calorie_label
                            text: "— Set profile data first —"
                            font_style: "Title"
                            role: "large"

                MacroPieChart:
                    id: pie_chart
                    protein_pct: root.protein_pct
                    carbs_pct: root.carbs_pct
                    fat_pct: root.fat_pct

                MDBoxLayout:
                    size_hint_y: None
                    height: "96dp"
                    spacing: "10dp"

                    MDCard:
                        padding: "10dp"
                        radius: [dp(12)]
                        elevation: 0
                        md_bg_color: app.theme_cls.surfaceContainerColor

                        MDLabel:
                            markup: True
                            text: root.carbs_breakdown_text
                            halign: "center"
                            valign: "middle"
                            text_size: self.size
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            font_style: "Body"
                            role: "small"

                    MDCard:
                        padding: "10dp"
                        radius: [dp(12)]
                        elevation: 0
                        md_bg_color: app.theme_cls.surfaceContainerColor

                        MDLabel:
                            markup: True
                            text: root.protein_breakdown_text
                            halign: "center"
                            valign: "middle"
                            text_size: self.size
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            font_style: "Body"
                            role: "small"

                    MDCard:
                        padding: "10dp"
                        radius: [dp(12)]
                        elevation: 0
                        md_bg_color: app.theme_cls.surfaceContainerColor

                        MDLabel:
                            markup: True
                            text: root.fat_breakdown_text
                            halign: "center"
                            valign: "middle"
                            text_size: self.size
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            font_style: "Body"
                            role: "small"

                AnchorLayout:
                    size_hint_y: None
                    height: "56dp"
                    anchor_x: "center"
                    anchor_y: "center"

                    MDCard:
                        size_hint_x: None
                        width: dp(280)
                        padding: ["20dp", "14dp", "20dp", "14dp"]
                        radius: [dp(12)]
                        elevation: 0
                        md_bg_color: app.theme_cls.surfaceContainerColor
                        ripple_behavior: True
                        on_release: root.open_macro_editor()

                        MDLabel:
                            text: "Edit macronutrients"
                            font_style: "Title"
                            role: "small"
                            halign: "center"
                            valign: "middle"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.primaryColor
