<EditMacrosSheet>:
    background: " "
    background_color: 0, 0, 0, 0
    auto_dismiss: False

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: app.theme_cls.backgroundColor

        MDBoxLayout:
            size_hint_y: None
            height: "56dp"
            md_bg_color: app.theme_cls.primaryColor
            spacing: "4dp"
            padding: ["4dp", "0dp", "16dp", "0dp"]

            MDIconButton:
                icon: "arrow-left"
                theme_icon_color: "Custom"
                icon_color: 1, 1, 1, 1
                pos_hint: {"center_y": 0.5}
                on_release: root.dismiss()

            MDLabel:
                text: "Edit macronutrients"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                font_style: "Title"
                role: "medium"
                halign: "left"
                valign: "center"

        MDBoxLayout:
            orientation: "vertical"
            padding: ["16dp", "20dp", "16dp", "24dp"]
            spacing: "16dp"

            MDCard:
                orientation: "vertical"
                padding: "16dp"
                spacing: "8dp"
                radius: [dp(12)]
                elevation: 0
                size_hint_y: None
                height: self.minimum_height

                MDTextField:
                    id: protein_input
                    hint_text: "Protein (%)"
                    input_filter: "float"

                MDTextField:
                    id: fat_input
                    hint_text: "Fat (%)"
                    input_filter: "float"

                MDTextField:
                    id: carbs_input
                    hint_text: "Carbohydrates (%)"
                    input_filter: "float"

                MDLabel:
                    text: "Total must equal 100%"
                    font_style: "Body"
                    role: "small"
                    theme_text_color: "Secondary"

            Widget:

            MDButton:
                style: "filled"
                size_hint_x: 1
                on_release: root.save_changes()

                MDButtonText:
                    text: "Save macronutrients"

<GoalsScreen>:
    MDBoxLayout:
        orientation: "vertical"

        MDBoxLayout:
            size_hint_y: None
            height: "56dp"
            md_bg_color: app.theme_cls.primaryColor
            padding: ["16dp", "0dp", "16dp", "0dp"]

            MDLabel:
                text: "Goals"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                font_style: "Title"
                role: "medium"
                halign: "center"
                valign: "center"

        MDScrollView:
            MDBoxLayout:
                orientation: "vertical"
                padding: ["16dp", "16dp", "16dp", "24dp"]
                spacing: "16dp"
                size_hint_y: None
                height: self.minimum_height

                MDCard:
                    padding: "16dp"
                    radius: [dp(12)]
                    elevation: 1
                    size_hint_y: None
                    height: "88dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: "4dp"

                        MDLabel:
                            text: "Daily calorie target"
                            font_style: "Label"
                            role: "medium"
                            theme_text_color: "Secondary"

                        MDLabel:
                            id: calorie_label
                            text: "— Set profile data first —"
                            font_style: "Title"
                            role: "large"

                MacroPieChart:
                    id: pie_chart
                    protein_pct: root.protein_pct
                    carbs_pct: root.carbs_pct
                    fat_pct: root.fat_pct

                MDButton:
                    style: "filled"
                    size_hint_x: 1
                    on_release: root.open_macro_editor()

                    MDButtonText:
                        text: "Edit macronutrients"
