<SettingsScreen>:
    MDBoxLayout:
        orientation: "vertical"

        MDBoxLayout:
            size_hint_y: None
            height: "56dp"
            md_bg_color: app.theme_cls.primaryColor
            padding: ["16dp", "0dp", "16dp", "0dp"]

            MDLabel:
                text: "Settings"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                font_style: "Title"
                role: "medium"
                halign: "center"
                valign: "center"

        MDScrollView:
            MDBoxLayout:
                orientation: "vertical"
                padding: ["16dp", "8dp", "16dp", "24dp"]
                spacing: "4dp"
                size_hint_y: None
                height: self.minimum_height

                # ── Unit system ────────────────────────────────────────
                MDListItem:
                    MDListItemHeadlineText:
                        text: "Unit System"

                    MDListItemSupportingText:
                        id: unit_label
                        text: "Metric / Imperial"

                    MDSwitch:
                        id: unit_switch
                        pos_hint: {"center_y": 0.5}
                        on_active: root.on_unit_toggled(self.active)

                MDDivider:
                    theme_divider_color: "Custom"
                    color: "#94A09F"

                # ── My Foods ───────────────────────────────────────────
                MDLabel:
                    text: "My Foods"
                    font_style: "Title"
                    role: "small"
                    padding: ["16dp", "12dp"]
                    size_hint_y: None
                    height: "44dp"

                MDBoxLayout:
                    id: my_foods_list
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height

                MDDivider:
                    theme_divider_color: "Custom"
                    color: "#94A09F"

                # ── Cloud ──────────────────────────────────────────────
                MDLabel:
                    text: "Cloud"
                    font_style: "Title"
                    role: "small"
                    padding: ["16dp", "12dp"]
                    size_hint_y: None
                    height: "44dp"

                MDListItem:
                    MDListItemHeadlineText:
                        id: online_indicator
                        text: "Not connected"

                    MDListItemSupportingText:
                        id: sync_status_label
                        text: "All data stored in cloud"

                MDDivider:
                    theme_divider_color: "Custom"
                    color: "#94A09F"

                # ── Export ─────────────────────────────────────────────
                MDLabel:
                    text: "Data"
                    font_style: "Title"
                    role: "small"
                    padding: ["16dp", "12dp"]
                    size_hint_y: None
                    height: "44dp"

                MDBoxLayout:
                    size_hint_y: None
                    height: "56dp"
                    padding: ["16dp", "4dp"]

                    MacrosOutlinedButton:
                        on_release: root.export_csv()

                        MDButtonText:
                            text: "Export Meal History (CSV)"

                MDDivider:
                    theme_divider_color: "Custom"
                    color: "#94A09F"

                # ── About ──────────────────────────────────────────────
                MDListItem:
                    MDListItemHeadlineText:
                        text: "Version"

                    MDListItemSupportingText:
                        text: app.version if hasattr(app, 'version') else "1.0.0"
