<SettingsScreen>:
    MDBoxLayout:
        orientation: "vertical"

        MDBoxLayout:
            size_hint_y: None
            height: "56dp"
            md_bg_color: app.theme_cls.primaryColor
            padding: ["16dp", "0dp", "16dp", "0dp"]

            MDLabel:
                text: "Settings"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                font_style: "Title"
                role: "medium"
                halign: "center"
                valign: "center"

        MDScrollView:
            MDBoxLayout:
                orientation: "vertical"
                padding: ["16dp", "8dp", "16dp", "24dp"]
                spacing: "4dp"
                size_hint_y: None
                height: self.minimum_height

                # ── Formula ────────────────────────────────────────────
                MDListItem:
                    on_release: root.open_formula()

                    MDListItemHeadlineText:
                        text: "Formula"

                    MDListItemSupportingText:
                        text: "How your calorie target is calculated"

                    MDListItemTrailingIcon:
                        icon: "chevron-right"

                MDDivider:

                # ── My Foods ───────────────────────────────────────────
                MDListItem:
                    padding: ["16dp", "14dp", "24dp", "14dp"]
                    on_release: root.open_my_foods()

                    MDListItemHeadlineText:
                        text: "My Foods"

                    MDListItemTrailingIcon:
                        icon: "chevron-right"

                MDDivider:

                # ── Cloud ──────────────────────────────────────────────
                MDLabel:
                    text: "Cloud"
                    font_style: "Title"
                    role: "small"
                    padding: ["16dp", "12dp"]
                    size_hint_y: None
                    height: "44dp"

                MDListItem:
                    MDListItemHeadlineText:
                        id: online_indicator
                        text: "Not connected"

                    MDListItemSupportingText:
                        id: sync_status_label
                        text: "All data stored in cloud"

                MDDivider:

                # ── Export ─────────────────────────────────────────────
                MDLabel:
                    text: "Data"
                    font_style: "Title"
                    role: "small"
                    padding: ["16dp", "12dp"]
                    size_hint_y: None
                    height: "44dp"

                MDBoxLayout:
                    size_hint_y: None
                    height: "56dp"
                    padding: ["16dp", "4dp"]

                    MacrosOutlinedButton:
                        on_release: root.export_csv()

                        MDButtonText:
                            text: "Export Meal History (CSV)"

                MDDivider:

                # ── About ──────────────────────────────────────────────
                MDListItem:
                    MDListItemHeadlineText:
                        text: "Version"

                    MDListItemSupportingText:
                        text: app.version if hasattr(app, 'version') else "1.0.0"
