#:import dp kivy.metrics.dp
#:import RGBA_PRIMARY utils.constants.RGBA_PRIMARY

<FoodEditScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: app.theme_cls.backgroundColor

        MDBoxLayout:
            size_hint_y: None
            height: "56dp"
            md_bg_color: RGBA_PRIMARY
            padding: ["4dp", "0dp", "8dp", "0dp"]

            MDIconButton:
                icon: "arrow-left"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                on_release: root.go_back()

            MDLabel:
                text: "Food"
                font_style: "Title"
                role: "medium"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                halign: "center"
                valign: "center"
                size_hint_x: 1

            MDIconButton:
                icon: "content-save"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                on_release: root.save_food()

        ScrollView:
            size_hint_y: 1
            bar_width: dp(5)
            do_scroll_x: False

            MDBoxLayout:
                id: scroll_inner
                orientation: "vertical"
                size_hint_y: None
                padding: ["16dp", "12dp", "16dp", "28dp"]
                spacing: "12dp"
                adaptive_height: True
                height: self.minimum_height
