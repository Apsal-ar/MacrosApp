#:import dp kivy.metrics.dp
#:import RGBA_PRIMARY utils.constants.RGBA_PRIMARY

<FoodSearchScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: app.theme_cls.backgroundColor

        # Unified header (#009688): title → search row → tabs
        # Explicit height: a vertical MDBoxLayout with only size_hint_y: None and no height can collapse
        # to ~tab height, hiding the title + search rows.
        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            size_hint_x: 1
            height: "156dp"
            md_bg_color: RGBA_PRIMARY

            # 1) Title "Search"
            MDBoxLayout:
                size_hint_y: None
                height: "56dp"
                padding: ["4dp", "0dp", "8dp", "0dp"]

                MDIconButton:
                    icon: "arrow-left"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    on_release: root.go_back()

                MDLabel:
                    text: "Search"
                    font_style: "Title"
                    role: "medium"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    halign: "center"
                    valign: "center"
                    size_hint_x: 1

                MDIconButton:
                    icon: "plus"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    on_release: root.open_manual_form()

            # 2) Search — padding area is teal; inner surface is the only contrasting bar
            MDBoxLayout:
                size_hint_y: None
                height: "52dp"
                padding: ["12dp", "6dp", "12dp", "6dp"]

                MDBoxLayout:
                    orientation: "horizontal"
                    spacing: "4dp"
                    md_bg_color: app.theme_cls.surfaceContainerHighColor
                    radius: [dp(12), dp(12), dp(12), dp(12)]
                    padding: ["2dp", "0dp", "6dp", "0dp"]
                    size_hint_y: None
                    height: "40dp"

                    MDIconButton:
                        icon: "magnify"
                        theme_text_color: "Custom"
                        text_color: app.theme_cls.primaryColor
                        pos_hint: {"center_y": 0.5}

                    MDTextField:
                        id: search_field
                        hint_text: "Search foods..."
                        mode: "outlined"
                        size_hint_x: 1
                        size_hint_y: None
                        height: "40dp"
                        on_text: root.on_search_text(self.text)

                    MDIconButton:
                        id: clear_search_btn
                        icon: "close"
                        opacity: 0
                        disabled: True
                        theme_text_color: "Custom"
                        text_color: app.theme_cls.primaryColor
                        pos_hint: {"center_y": 0.5}
                        on_release: root.clear_search()

                    MDIconButton:
                        icon: "barcode-scan"
                        theme_text_color: "Custom"
                        text_color: app.theme_cls.primaryColor
                        pos_hint: {"center_y": 0.5}
                        on_release: root.on_scan_pressed()

            # 3) Tabs
            MDBoxLayout:
                id: tab_row
                size_hint_y: None
                height: "48dp"
                spacing: "4dp"
                padding: ["8dp", "0dp", "8dp", "8dp"]

                MacrosTextButton:
                    id: tab_b0
                    on_release: root.set_tab(0)

                    MDButtonText:
                        text: "My foods"

                MacrosTextButton:
                    id: tab_b1
                    on_release: root.set_tab(1)

                    MDButtonText:
                        text: "My recipes"

                MacrosTextButton:
                    id: tab_b2
                    on_release: root.set_tab(2)

                    MDButtonText:
                        text: "Library"

        MDDivider:
            theme_divider_color: "Custom"
            color: "#94A09F"

        MDScrollView:
            size_hint_y: 1
            bar_width: dp(5)
            do_scroll_x: False

            MDBoxLayout:
                id: results_outer
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height

                MDList:
                    id: results_list
                    size_hint_y: None
                    height: self.minimum_height

        MDBoxLayout:
            id: quantity_row
            orientation: "horizontal"
            size_hint_y: None
            height: "0dp"
            opacity: 0
            spacing: "8dp"
            padding: ["12dp", "4dp", "12dp", "8dp"]

            MDTextField:
                id: quantity_field
                hint_text: "Quantity (g)"
                input_filter: "float"
                text: "100"
                size_hint_x: 0.38

            MDBoxLayout:
                orientation: "horizontal"
                spacing: "8dp"
                size_hint_x: 0.62

                MacrosFilledButton:
                    size_hint_x: 0.6667
                    on_release: root.on_confirm_quantity()

                    MDButtonText:
                        text: "Next"

                MacrosTextButton:
                    size_hint_x: 0.3333
                    on_release: root.on_edit_quantity_row()

                    MDButtonText:
                        text: "Edit"
                        theme_text_color: "Custom"
                        text_color: app.theme_cls.primaryColor

        MDBoxLayout:
            id: manual_form
            orientation: "vertical"
            size_hint_y: None
            height: "0dp"
            opacity: 0
            spacing: "4dp"
            padding: ["12dp", "4dp", "12dp", "12dp"]

            MDLabel:
                text: "Enter food details manually"
                font_style: "Title"
                role: "small"

            MDTextField:
                id: manual_name
                hint_text: "Food name *"

            MDBoxLayout:
                size_hint_y: None
                height: "56dp"
                spacing: "8dp"

                MDTextField:
                    id: manual_calories
                    hint_text: "Calories/100g"
                    input_filter: "float"

                MDTextField:
                    id: manual_protein
                    hint_text: "Protein (g)"
                    input_filter: "float"

            MDBoxLayout:
                size_hint_y: None
                height: "56dp"
                spacing: "8dp"

                MDTextField:
                    id: manual_carbs
                    hint_text: "Carbs (g)"
                    input_filter: "float"

                MDTextField:
                    id: manual_fat
                    hint_text: "Fat (g)"
                    input_filter: "float"

            MacrosFilledButton:
                on_release: root.on_save_manual()

                MDButtonText:
                    text: "Save & Use"
